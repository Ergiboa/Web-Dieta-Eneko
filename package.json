{
  "name": "nutricoach",
  "version": "1.0.0",
  "description": "Plataforma de coaching nutricional y entrenamiento",
  "main": "main.js",
  "author": "NutriCoach",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win --mac --linux"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.nutricoach.app",
    "productName": "NutriCoach",
    "copyright": "NutriCoach",
    "directories": {
      "output": "dist"
    },
    "files": [
      "app.html",
      "login.html",
      "manifest.json",
      "sw.js",
      "main.js",
      "icon-192.png",
      "icon-512.png",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "icon-512.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NutriCoach",
      "installerHeaderIcon": "icon-512.png",
      "uninstallDisplayName": "NutriCoach"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon-512.png",
      "category": "public.app-category.healthcare-fitness"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon-512.png",
      "category": "Science"
    }
  }
}